# Config do frontend (Vite). Copie para .env e ajuste.
# .env NÃO é versionado (ver .gitignore).

# URL base que o axios usa. Deixe /api (relativo): em DEV o proxy do Vite
# encaminha; em produção o nginx serve /api no mesmo host. Sem CORS, sem host fixo.
VITE_API_URL=/api

# Alvo do proxy do Vite em DEV para /api. Aponte para a sua API:
#   local:  http://localhost:3000
#   EC2:    http://SEU_IP_PUBLICO:3000
VITE_API_PROXY_TARGET=http://localhost:3000
