# Config do deploy-web.sh (copie para deploy-web.env e preencha).
# deploy-web.env NÃO é versionado.

# Caminho da sua chave SSH (.pem) do EC2.
#   Ex. Git Bash: /c/Users/cassio.souza/Downloads/billing.pem
EC2_KEY=/c/Users/SEU_USUARIO/caminho/chave.pem

# Usuário e IP (Elastic IP) do EC2.
EC2_HOST=ec2-user@SEU_ELASTIC_IP

# (opcional) Destino do build no EC2 — precisa bater com o volume do Caddy
# no docker-compose (./frontend/dist). Normalmente não muda.
# EC2_PATH=~/billing-automation-api/frontend/dist
